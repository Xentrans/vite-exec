{
  "name": "vite-exec",
  "version": "0.1.1",
  "description": "A CLI for running TS/JS files through Vite. Similar to tsx or ts-node, but powered by Vite's ModuleRunner.",
  "type": "module",
  "bin": {
    "vite-exec": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "pretest": "npm run build",
    "test": "node --test --experimental-strip-types test/*.test.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/picomatch": "^4.0.3",
    "typescript": "^5.8.0"
  },
  "keywords": [
    "vite",
    "typescript",
    "ts-node",
    "tsx",
    "vite-node",
    "module-runner",
    "cli",
    "runner"
  ],
  "license": "MIT",
  "author": "Xentelligent Ltd.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xentrans/vite-exec.git"
  },
  "homepage": "https://github.com/Xentrans/vite-exec#readme",
  "bugs": {
    "url": "https://github.com/Xentrans/vite-exec/issues"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "picomatch": "^4.0.0",
    "vite": "^8.0.0"
  }
}
